# OpenAI API 密钥（或与下方 API_BASE_URL 配套的兼容网关密钥）
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI 兼容接口地址（如 edgefn 等第三方网关；留空则使用官方 api.openai.com）
# API_BASE_URL=https://api.edgefn.net/v1

# Anthropic API 密钥（可选）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Semantic Scholar API（基础使用无需密钥）
SEMANTIC_SCHOLAR_API_KEY=optional_semantic_scholar_api_key

# 应用程序设置
MAX_PAPERS_TO_RETRIEVE=10
LLM_MODEL=gpt-4o-mini  # 官方模型；若使用兼容网关可改为网关提供的模型名，如 DeepSeek-V3.2
MAX_TOKENS=2000
TEMPERATURE=0.1  # 低温度以获得更多事实性响应
RATE_LIMIT_DELAY=0.1
USE_MOCK_DATA=false  # 设置为true使用模拟数据（用于测试）
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0